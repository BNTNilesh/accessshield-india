{
  "name": "@accessshield/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "echo \"No tests yet\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bash scripts/seed-dev.sh",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.31.2",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@accessshield/config": "workspace:*",
    "@accessshield/types": "workspace:*",
    "drizzle-kit": "^0.22.7",
    "eslint": "^8.57.0",
    "typescript": "^5.5.2"
  }
}

    "amqplib": "^0.10.4",
    "axe-core": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.31.2",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jose": "^5.6.3",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "playwright": "^1.60.0",
    "sharp": "^0.33.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@accessshield/config": "workspace:*",
    "@axe-core/playwright": "^4.9.0",
    "@types/amqplib": "^0.10.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/sharp": "^0.32.0",
    "eslint": "^8.57.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }

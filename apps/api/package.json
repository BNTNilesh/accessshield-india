{
  "name": "@accessshield/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/scanner/worker-entry.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/scanner/worker.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@accessshield/db": "workspace:*",
    "@accessshield/types": "workspace:*",

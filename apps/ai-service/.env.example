# AccessShield AI Service Configuration
# Copy to .env and fill in values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Internal service authentication key (required)
# Generate with: openssl rand -hex 32
INTERNAL_AI_SERVICE_KEY=your-internal-key-here

# Redis URL
REDIS_URL=redis://localhost:6379

# PostgreSQL Database URL (async format)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/accessshield

# Claude model — must match a model enabled on your Anthropic account
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Token limits per service
MAX_TOKENS_ALT_TEXT=256
MAX_TOKENS_FIX=1024
MAX_TOKENS_ADVICE=512
MAX_TOKENS_STATEMENT=2048

# Cache TTL in seconds (default 24 hours)
CACHE_TTL_SECONDS=86400

# Request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30

# Environment: development | staging | production
ENVIRONMENT=development

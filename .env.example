# ─── Local development only — copy to .env.local ───────────────────────────
# Never commit .env.local. Production uses AWS Secrets Manager.

# Database (local Docker Postgres or Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/accessshield

# Redis (local Docker or Upstash)
REDIS_URL=redis://localhost:6379

# RabbitMQ (local Docker or CloudAMQP)
RABBITMQ_URL=amqp://accessshield:accessshield@localhost:5672

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=
# Admin API — set test user app_metadata (scripts/set-test-user-claims.sh)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# API
PORT=4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
NEXT_PUBLIC_API_URL=http://localhost:4000

# Marketing site accessibility widget (dogfood)
# Token: Dashboard → Settings → Widget, or deriveDefaultToken for platform org in dev
NEXT_PUBLIC_WIDGET_ENABLED=true
NEXT_PUBLIC_WIDGET_TOKEN=b8a52e20c0f903cb181501b3cf55c8c3
# Leave empty in dev to serve /widget.js from apps/web/public; set for prod CDN
# NEXT_PUBLIC_CDN_URL=https://cdn.accessshield.in

# AI service (apps/ai-service — run separately on port 8001)
AI_SERVICE_URL=http://localhost:8001
INTERNAL_AI_SERVICE_KEY=dev-internal-ai-key
ANTHROPIC_API_KEY=

# Dev: skip monthly scan limit (defaults off in production)
SCAN_LIMIT_DISABLED=true

# Sysadmin seed script (scripts/seed-sysadmin.sh) — never commit real passwords
SYSADMIN_INITIAL_PASSWORD=your-sysadmin-password-here

# Sanity CMS (optional — blog works without these; homepage/blog show empty state)
# NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
# NEXT_PUBLIC_SANITY_DATASET=production

# AWS (production only)
# AWS_SECRET_ID=accessshield/prod
# AWS_REGION=ap-south-1
